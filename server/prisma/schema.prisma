generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  phone        String?
  email        String?
  username     String?   @unique
  password     String
  role         String    @default("user")
  isVerified   Boolean   @default(false)
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  halls        Hall[]    @relation("HallOwner")
  bookings     Booking[]

  @@index([role])
}

model Hall {
  id           String    @id @default(uuid())
  name         String
  description  String?
  badge        String?
  rating       Float     @default(4.5)
  amenities    Json      @default("[]")
  photos       Json      @default("[]")
  district     String
  address      String
  capacity     Int
  pricePerSeat Int
  phone        String
  ownerId      String?
  owner        User?     @relation("HallOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status       String    @default("pending")
  services     Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@index([district])
  @@index([ownerId])
  @@index([status])
}

model Booking {
  id               String   @id @default(uuid())
  hallId           String
  hall             Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             DateTime @db.Date
  seats            Int
  selectedServices Json     @default("{}")
  totalPrice       Int
  advancePaid      Int
  cancelled        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([cancelled])
  @@index([hallId, date])
  @@index([userId])
}
