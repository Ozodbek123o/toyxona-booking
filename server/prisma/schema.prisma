generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin @map("ADMIN")
  owner @map("OWNER")
  user  @map("CUSTOMER")

  @@map("user_role")
}

enum District {
  Chilanzar
  Yunusabad
  Mirabad
  Yakkasaray
  Shaykhantahur
  Almazar
  Mirzo_Ulugbek
  Uchtepa
  Sergeli
  Bektemir
  Yashnabad
  Yangihayot

  @@map("district_enum")
}

enum HallStatus {
  pending  @map("PENDING")
  approved @map("APPROVED")

  @@map("hall_status")
}

enum BookingStatus {
  upcoming  @map("UPCOMING")
  completed @map("COMPLETED")
  cancelled @map("CANCELLED")

  @@map("booking_status")
}

enum ServiceType {
  singer        @map("SINGER")
  car           @map("CAR")
  karnay_surnay @map("KARNAY_SURNAY")

  @@map("service_type")
}

model User {
  id         Int      @id @default(autoincrement())
  firstName  String   @map("first_name") @db.VarChar(100)
  lastName   String   @map("last_name") @db.VarChar(100)
  phone      String   @map("phone_number") @db.VarChar(20)
  email      String   @unique @db.VarChar(150)
  username   String   @unique @db.VarChar(50)
  password   String   @map("password_hash") @db.VarChar(255)
  role       UserRole @default(user)
  isVerified Boolean  @default(false) @map("is_verified")
  otpCode    String?  @map("otp_code") @db.VarChar(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  halls    Hall[]    @relation("HallOwner")
  bookings Booking[]

  @@index([role])
  @@map("users")
}

model Hall {
  id                Int        @id @default(autoincrement())
  ownerId           Int        @map("owner_id")
  name              String     @db.VarChar(255)
  district          District
  address           String
  capacity          Int
  pricePerSeat      Decimal    @map("price_per_seat") @db.Decimal(12, 2)
  phone             String     @map("phone_number") @db.VarChar(20)
  status            HallStatus @default(pending)
  hasKarnaySurnay   Boolean    @default(false) @map("has_karnay_surnay")
  karnaySurnayPrice Decimal?   @map("karnay_surnay_price") @db.Decimal(12, 2)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamp(6)

  owner    User        @relation("HallOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  images   HallImage[]
  singers  Singer[]
  cars     Car[]
  menus    Menu[]
  bookings Booking[]

  @@index([ownerId], map: "idx_wedding_halls_owner_id")
  @@index([district])
  @@index([status])
  @@map("wedding_halls")
}

model HallImage {
  id       Int    @id @default(autoincrement())
  hallId   Int    @map("hall_id")
  imageUrl String @map("image_url")

  hall Hall @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hallId], map: "idx_hall_images_hall_id")
  @@map("hall_images")
}

model Singer {
  id       Int     @id @default(autoincrement())
  hallId   Int     @map("hall_id")
  name     String  @db.VarChar(255)
  price    Decimal @db.Decimal(12, 2)
  imageUrl String? @map("image_url")
  hall     Hall    @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hallId], map: "idx_singers_hall_id")
  @@map("singers")
}

model Car {
  id       Int     @id @default(autoincrement())
  hallId   Int     @map("hall_id")
  brand    String  @db.VarChar(255)
  price    Decimal @db.Decimal(12, 2)
  imageUrl String? @map("image_url")
  hall     Hall    @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hallId], map: "idx_cars_hall_id")
  @@map("cars")
}

model Menu {
  id       Int     @id @default(autoincrement())
  hallId   Int     @map("hall_id")
  name     String  @db.VarChar(255)
  imageUrl String? @map("image_url")
  hall     Hall    @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hallId], map: "idx_menus_hall_id")
  @@map("menus")
}

model Booking {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("customer_id")
  hallId      Int           @map("hall_id")
  date        DateTime      @map("booking_date") @db.Date
  seats       Int           @map("guest_count")
  totalPrice  Decimal       @map("total_price") @db.Decimal(12, 2)
  advancePaid Decimal       @map("deposit_paid") @db.Decimal(12, 2)
  status      BookingStatus @default(upcoming)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  user     User             @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  hall     Hall             @relation(fields: [hallId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  services BookingService[]

  @@index([userId], map: "idx_bookings_customer_id")
  @@index([hallId], map: "idx_bookings_hall_id")
  @@map("bookings")
}

model BookingService {
  id            Int         @id @default(autoincrement())
  bookingId     Int         @map("booking_id")
  serviceType   ServiceType @map("service_type")
  serviceItemId Int?        @map("service_item_id")
  price         Decimal     @db.Decimal(12, 2)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([bookingId], map: "idx_booking_services_booking_id")
  @@index([serviceType, serviceItemId], map: "idx_booking_services_type_item")
  @@map("booking_services")
}
