{
	"name": "backend",
	"type": "module",
	"scripts": {
		"dev": "nodemon src/index.js",
		"start": "node src/index.js",
		"test": "node --test src/utils/*.test.js",
		"check": "npm test && prisma validate",
		"postinstall": "prisma generate",
		"db:push": "prisma db push",
		"db:init": "prisma db execute --file prisma/init.sql --schema prisma/schema.prisma",
		"db:indexes": "prisma db execute --file prisma/production-indexes.pgsql.sql --schema prisma/schema.prisma",
		"db:setup": "prisma generate && prisma db execute --file prisma/init.sql --schema prisma/schema.prisma && prisma db execute --file prisma/production-indexes.pgsql.sql --schema prisma/schema.prisma",
		"db:studio": "prisma studio",
		"db:reset-passwords": "node scripts/reset-passwords.mjs",
		"db:ping": "node scripts/test-db.mjs"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0",
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"express-rate-limit": "^8.5.2",
		"helmet": "^8.2.0",
		"jsonwebtoken": "^9.0.2",
		"multer": "1.4.5-lts.1",
		"nodemailer": "^8.0.8"
	},
	"devDependencies": {
		"nodemon": "^3.1.4",
		"prisma": "^5.22.0"
	}
}
