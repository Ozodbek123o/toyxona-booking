NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret

# Optional: create an admin from env on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@toyxona.uz

# Keep false in production. Set true only for local/demo data.
SEED_DEMO=false

# Repair admin password when SQL seed used placeholder hashes.
SYNC_ADMIN_PASSWORD=false

OWNER_USERNAME=
OWNER_PASSWORD=
OWNER_FIRST_NAME=
OWNER_LAST_NAME=
OWNER_EMAIL=
OWNER_PHONE=
SYNC_OWNER_PASSWORD=false

USER_USERNAME=
USER_PASSWORD=
USER_FIRST_NAME=
USER_LAST_NAME=
USER_EMAIL=
USER_PHONE=
SYNC_USER_PASSWORD=false

RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
JSON_LIMIT=1mb
MAX_UPLOAD_BYTES=5242880

# Optional SMTP for owner OTP emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@toyxona.local
